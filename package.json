{
  "name": "claude-codex-orchestrator",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "bin": {
    "orch-health": "./dist/orch-health/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run && bash tests/run-hook-tests.sh",
    "test:unit": "vitest run",
    "test:hooks": "bash tests/run-hook-tests.sh",
    "eval": "bash hooks/scripts/eval-runner.sh",
    "check": "node dist/orch-health/cli.js check",
    "doctor": "node dist/orch-health/cli.js doctor",
    "status": "node dist/orch-health/cli.js status"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
